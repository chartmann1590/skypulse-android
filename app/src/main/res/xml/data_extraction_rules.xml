<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude all files from cloud backup to mimic allowBackup="false" -->
        <exclude path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude all files from device-to-device transfer -->
        <exclude path="." />
    </device-transfer>
</data-extraction-rules>
