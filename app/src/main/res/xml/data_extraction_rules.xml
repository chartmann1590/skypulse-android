<?xml version="1.0" encoding="utf-8"?>
<!--
  Backups are disabled (android:allowBackup="false"), but these rules are declared so that,
  even if a backup/transfer path is ever enabled, no on-device data leaves the device.
  Each <exclude> requires a `domain`; excluding every domain opts everything out.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
